              Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Button x:Name="ClearButton"
                    Grid.Row="0"
                    Grid.Column="0"
                    Click="ClearButton_Click">
                New Game
            </Button>
            
            <Button x:Name="StartButton"
                    Grid.Row="0"
                    Grid.Column="1"
                    IsEnabled="False"
                    Click="StartButton_Click">
                Start
            </Button>
            
            <Button x:Name="SwitchButton"
                    Grid.Row="1"
                    Grid.Column="0"
                    Click="SwitchButton_Click">
                Switch Players
            </Button>
        </Grid>
        
        <StackPanel Grid.Row="0"
                    Grid.Column="1"
                    Grid.RowSpan="2">
            <TextBlock HorizontalAlignment="Center">
                AI Options
            </TextBlock>
            
            <Separator />
            
            <CheckBox IsChecked="{Binding Randomness}">
                Randomness
            </CheckBox>
            <CheckBox IsChecked="{Binding Training}">
                Training
            </CheckBox>

            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Margin="5,5,0,0">
                    Search Depth:
                </TextBlock>
                <TextBlock DockPanel.Dock="Right"
                           Margin="0,5,5,0"
                           Text="{Binding SearchDepth}" />
            </DockPanel>
            <Slider Minimum="1"
                    Maximum="10"
                    TickFrequency="1"
                    IsSnapToTickEnabled="True"
                    Value="{Binding SearchDepth}" />
        </StackPanel>
